# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# TarvaRI Backend API (required for data — defaults to http://localhost:8000 if omitted)
NEXT_PUBLIC_TARVARI_API_URL=http://localhost:8000

# Data mode: 'console' (TarvaRI API) or 'supabase' (direct Supabase queries)
# Console mode requires TarvaRI backend running. Supabase mode is for static/public builds.
# Defaults to 'console' if omitted.
NEXT_PUBLIC_DATA_MODE=console

# Claude API Integration (WS-4.1)
# Set your Anthropic API key to enable Claude-powered features.
# Without this key, all AI features work via Ollama (local) + rule engines.
#
# Get your key at: https://console.anthropic.com/settings/keys
#
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Override the default Claude model (claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
